		"bits-ui": "1.0.0-next.98",
		"clsx": "^2.1.1",
		"eslint": "^9.20.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"formsnap": "2.0.0-next.1",
		"globals": "^15.15.0",
